{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile",
    "watchPaths": [
      "Dockerfile",
      "pnpm-lock.yaml",
      "package.json",
      "tsconfig.json",
      "tsconfig.build.json",
      "nest-cli.json",
      "src/**"
    ]
  },
  "deploy": {
    "startCommand": "node dist/main.js",
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "healthcheckPath": "/",
    "sleep": false
  }
}
