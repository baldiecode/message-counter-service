# Ignore node modules and debug logs
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Ignore local env files
.env
.env.*
!.env.example

# VCS and editor
.git
.gitignore
.vscode
.idea

# Build outputs and coverage
dist
coverage
.tmp
.temp
.DS_Store

# Tests caches
.jest*
.nyc_output

# Docker
Dockerfile.*
docker-compose*.yml